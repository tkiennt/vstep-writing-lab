{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --lan --port 8090",
    "start:qr": "expo start --clear --lan --port 8090",
    "qr": "expo start --clear --lan --port 8090",
    "start:tunnel": "expo start --tunnel --port 8090",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android",
    "build:apk:debug": "expo prebuild --platform android && cd android && gradlew.bat assembleDebug",
    "eas:dev:android": "npx eas-cli@latest build -p android --profile development",
    "eas:dev:ios": "npx eas-cli@latest build -p ios --profile development",
    "eas:apk:preview": "npx eas-cli@latest build -p android --profile preview",
    "eas:preview:ios": "npx eas-cli@latest build -p ios --profile preview",
    "eas:aab:prod": "npx eas-cli@latest build -p android --profile production",
    "eas:ios:prod": "npx eas-cli@latest build -p ios --profile production",
    "eas:submit:android": "npx eas-cli@latest submit -p android --profile production",
    "eas:submit:ios": "npx eas-cli@latest submit -p ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.11.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
