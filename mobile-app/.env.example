# API (backend VstepWritingLab.API — dotnet run → http://0.0.0.0:5288)
#
# Một dòng EXPO_PUBLIC_API_URL duy nhất (dotenv dùng dòng sau nếu trùng tên — tránh ghi hai lần).
#
# Không chèn khoảng trắng trong URL (vd. sai: 10.0.0 .1 — sẽ không kết nối được).
# Điện thoại thật + WiFi: ipconfig → IPv4 (vd. http://192.168.1.50:5288)
# Emulator Android: http://localhost:5288 hoặc http://127.0.0.1:5288 → src/config/env.ts map sang 10.0.2.2
# USB + adb reverse: adb reverse tcp:5288 tcp:5288 rồi có thể dùng http://127.0.0.1:5288
EXPO_PUBLIC_API_URL=http://localhost:5288

# Firebase (same as web project)
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyBEPHGDf5nUhMkD4U3qinSpVdxoVpkdMfg
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=vstep-writing-lab.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=vstep-writing-lab
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=vstep-writing-lab.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=958279733063
EXPO_PUBLIC_FIREBASE_APP_ID=1:958279733063:web:ef7e0d43d24ddf414b0662
